{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Functions App",
            "type": "coreclr",
            "request": "launch",
            "program": "func",
            "args": [
                "host",
                "start",
                "--pause-on-error"
            ],
            "cwd": "${workspaceFolder}/rag/src/FunctionsApp",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "preLaunchTask": "build",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}